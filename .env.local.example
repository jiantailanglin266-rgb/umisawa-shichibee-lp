# ── サイト基本設定 ──────────────────────────────
NEXT_PUBLIC_SITE_URL=https://umisawa-shichibee.jp

# ── Resend（メール登録の通知）────────────────────
# https://resend.com で取得した API キー
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# 事前通知リスト登録の控えを受け取る運営アドレス
CONTACT_TO_EMAIL=info@umisawa-shichibee.jp
# 送信元（Resend で認証済みドメインのアドレス）
CONTACT_FROM_EMAIL=noreply@umisawa-shichibee.jp

# ── Makuake 公開後に設定（任意）──────────────────
# プロジェクト URL。設定するとCTAが「事前通知」から「支援する」へ切替わる
NEXT_PUBLIC_MAKUAKE_URL=

# ── microCMS（CMS 接続時に設定。未設定ならダミーデータ）─
MICROCMS_SERVICE_DOMAIN=
MICROCMS_API_KEY=
