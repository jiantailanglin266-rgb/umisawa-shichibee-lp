# ── サイト基本設定 ──────────────────────────────
NEXT_PUBLIC_SITE_URL=https://unazawa-shichibee.jp

# ── フォーム実送信（Formspree・静的サイト対応）──────
# https://formspree.io で無料フォームを作成し、フォームID（xxxxxxxx の部分）を設定。
# 設定すると Contact・Reserve の送信が実際に届きます（未設定ならデモ）。
NEXT_PUBLIC_FORMSPREE_ID=

# ── Makuake 公開後に設定（任意）──────────────────
# プロジェクト URL。設定するとCTAが「事前通知」から「支援する」へ切替わる
NEXT_PUBLIC_MAKUAKE_URL=

# ── microCMS（CMS 接続時に設定。未設定ならダミーデータ）─
MICROCMS_SERVICE_DOMAIN=
MICROCMS_API_KEY=
